{
  "name": "@steipete/inngest",
  "version": "0.10.3",
  "description": "CLI for managing Inngest jobs - watch, cancel, filter by status",
  "keywords": [
    "cli",
    "inngest",
    "jobs",
    "monitoring",
    "workflow"
  ],
  "homepage": "https://github.com/steipete/inngest#readme",
  "bugs": {
    "url": "https://github.com/steipete/inngest/issues"
  },
  "license": "MIT",
  "author": "Peter Steinberger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steipete/inngest.git"
  },
  "bin": {
    "inngest": "dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm run format:check && oxlint --deny-warnings src test",
    "lint:fix": "pnpm run format && oxlint --fix src test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm run lint && pnpm run build && pnpm run test",
    "prepublishOnly": "pnpm run check"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ora": "^9.4.0",
    "vitest": "^4.1.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260503.1",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
